{
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "workers/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "export NODE_ENV=development; bun run build",
    "lint": "turbo lint:css lint:fmt lint:js lint:js2 lint:ts",
    "lint:css": "stylelint '**/*.{css,xcss}'",
    "lint:fmt": "biome check",
    "lint:js": "oxlint --ignore-path=.gitignore --format=stylish",
    "lint:js2": "eslint",
    "lint:ts": "tsc --build --noEmit",
    "test": "bun test --only-failures",
    "test:ci": "bun test --coverage --randomize --rerun-each=3",
    "typegen": "turbo typegen"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@cloudflare/workers-types": "5.20260703.1",
    "@eslint/js": "10.0.1",
    "@maxmilton/eslint-config": "0.3.2",
    "@maxmilton/oxlint-config": "0.0.3",
    "@maxmilton/stylelint-config": "0.4.3",
    "@maxmilton/test-utils": "0.0.15",
    "@types/bun": "1.3.14",
    "@types/node": "26.1.0",
    "eslint": "10.6.0",
    "eslint-plugin-oxlint": "1.72.0",
    "eslint-plugin-unicorn": "70.0.0",
    "happy-dom": "20.10.6",
    "oxlint": "1.72.0",
    "stylelint": "17.14.0",
    "stylelint-config-standard": "40.0.0",
    "turbo": "2.10.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "wrangler": "4.107.0"
  },
  "packageManager": "bun@1.99.0"
}
